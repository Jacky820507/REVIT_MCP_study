+                }
+                else // Y軸
+                {
+                    // Y軸：從 MinY 到 MaxY
+                    double centerX = (min.X + max.X) / 2;
+                    point1 = new XYZ(centerX, min.Y, min.Z);
+                    point2 = new XYZ(centerX, max.Y, min.Z);
